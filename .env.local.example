# Supabase — copy from your project's API settings
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Used server-side only for encrypted credential storage (pgcrypto)
# Generate a strong random string — never expose this publicly
CREDENTIAL_ENCRYPTION_KEY=replace-with-a-strong-random-secret
